# ==========================================
# PRODUCTION DATABASE - Vercel/Railway/RDS
# ==========================================
# Set DATABASE_URL in Vercel environment variables
# Format: postgresql://user:password@host:port/database?schema=public
# Example: postgresql://school_admin:password123@db.railway.app:5432/school_db?schema=public
DATABASE_URL="postgresql://user:password@host:port/database"

# ==========================================
# LOCAL DEVELOPMENT ONLY
# ==========================================
# For local development with Railway PostgreSQL:
# 1. Create a PostgreSQL database on Railway (railway.app)
# 2. Get the connection string from Railway dashboard
# 3. Set it as DATABASE_URL above
#
# OR for local development with Docker PostgreSQL:
# 1. docker run --name postgres -e POSTGRES_PASSWORD=password -d postgres
# 2. Update DATABASE_URL with docker container connection
#
# NOTE: Embedded PostgreSQL is only for development without external DB
# See LOCAL_DEVELOPMENT.md for setup instructions

# ==========================================
# AUTHENTICATION
# ==========================================
JWT_ACCESS_SECRET="replace-with-a-long-random-access-secret-min-32-chars"
JWT_REFRESH_SECRET="replace-with-a-long-random-refresh-secret-min-32-chars"
ACCESS_TOKEN_EXPIRES_IN="15m"
REFRESH_TOKEN_EXPIRES_IN="7d"

# ==========================================
# APPLICATION PORTS
# ==========================================
API_PORT="4000"

# ==========================================
# FRONTEND CONFIGURATION
# ==========================================
WEB_ORIGIN="http://localhost:3000"
NEXT_PUBLIC_API_URL="http://localhost:4000"

# ==========================================
# PRODUCTION ENVIRONMENT VARIABLES
# ==========================================
# Only set these in Vercel/production environment:
# NODE_ENV=production
# LOG_LEVEL=info
# SENTRY_DSN=https://xxxxx@sentry.io/xxxxx
# (Add other external service keys as needed)

