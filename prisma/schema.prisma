generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RoleCode {
  SUPER_ADMIN
  SCHOOL_ADMIN
  TEACHER
  STUDENT
  PARENT
  STAFF
  FINANCE_OFFICER
  LIBRARIAN
  HR_OFFICER
}

enum MembershipStatus {
  ACTIVE
  INVITED
  SUSPENDED
}

enum SessionStatus {
  ACTIVE
  REVOKED
  EXPIRED
}

enum AuditAction {
  LOGIN
  LOGOUT
  ACCESS_DENIED
  SESSION_REFRESH
  CREATE
  UPDATE
  DELETE
  EXPORT
  BACKUP
  RESTORE
  SETTINGS_UPDATE
}

enum SchoolStatus {
  ACTIVE
  TRIAL
  SUSPENDED
  ARCHIVED
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  PAST_DUE
  CANCELLED
  EXPIRED
}

enum BackupStatus {
  COMPLETED
  FAILED
  RESTORED
}

enum LeaveRequestType {
  FULL_DAY
  MULTI_DAY
  HALF_DAY
  LATE_ARRIVAL
  EARLY_PICKUP
  MEDICAL_APPOINTMENT
  EMERGENCY
  FAMILY
  OTHER
}

enum LeaveRequestStatus {
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  REJECTED
  CLARIFICATION_REQUESTED
  CANCELLED
}
model User {
  id           String             @id @default(cuid())
  email        String             @unique
  passwordHash String
  name         String
  isActive     Boolean            @default(true)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  memberships  SchoolMembership[]
  sessions     Session[]
  auditLogs    AuditLog[]
  twoFactorSettings UserTwoFactorSetting[]
  teacherClassrooms TeacherClassroom[]
  teacherAttendance TeacherAttendance[]
  teacherAssignments TeacherAssignment[]
  teacherExamPlans TeacherExamPlan[]
  teacherMarks TeacherMark[]
  teacherMaterials TeacherMaterial[]
  parentCommunications ParentCommunication[]
  onlineClasses OnlineClass[]
  studentAssignmentSubmissions StudentAssignmentSubmission[]
  studentExamAttempts StudentOnlineExamAttempt[]
  studentCertificates StudentCertificate[]
  studentTranscripts StudentTranscript[]
  studentFeePayments StudentFeePayment[]
  parentFeePayments ParentFeePayment[]
  parentPortalMessages ParentPortalMessage[]
  leaveRequestsRequested LeaveRequest[] @relation("LeaveRequestRequestedBy")
  leaveRequestsReviewed LeaveRequest[] @relation("LeaveRequestReviewedBy")
  leaveRequestTimelineEvents LeaveRequestTimeline[] @relation("LeaveRequestTimelineActor")
}

model School {
  id          String             @id @default(cuid())
  name        String
  slug        String             @unique
  status      SchoolStatus       @default(TRIAL)
  email       String?
  phone       String?
  address     String?
  website     String?
  deletedAt   DateTime?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  memberships SchoolMembership[]
  auditLogs   AuditLog[]
  subscriptions Subscription[]
  academicYears AcademicYear[]
  classLevels ClassLevel[]
  sections Section[]
  subjects Subject[]
  teacherProfiles TeacherProfile[]
  studentProfiles StudentProfile[]
  feeRecords FeeRecord[]
  examRecords ExamRecord[]
  attendanceRecords AttendanceRecord[]
  libraryBooks LibraryBook[]
  timetableSlots TimetableSlot[]
  attendanceNotifications AttendanceNotification[]
  teacherClassrooms TeacherClassroom[]
  teacherAttendance TeacherAttendance[]
  teacherAssignments TeacherAssignment[]
  teacherExamPlans TeacherExamPlan[]
  teacherMarks TeacherMark[]
  teacherMaterials TeacherMaterial[]
  parentCommunications ParentCommunication[]
  onlineClasses OnlineClass[]
  studentOnlineExams StudentOnlineExam[]
  studentAssignmentSubmissions StudentAssignmentSubmission[]
  studentExamAttempts StudentOnlineExamAttempt[]
  studentCertificates StudentCertificate[]
  studentTranscripts StudentTranscript[]
  studentFeePayments StudentFeePayment[]
  parentFeePayments ParentFeePayment[]
  parentPortalMessages ParentPortalMessage[]
  leaveRequests LeaveRequest[]
  admissionApplications AdmissionApplication[]
  admissionEnrollments AdmissionEnrollment[]
  admissionDocuments AdmissionDocument[]
  admissionReports AdmissionReport[]
  academicTerms AcademicTerm[]
  curriculumPlans CurriculumPlan[]
  examinationSchedules ExaminationSchedule[]
  questionBankItems QuestionBankItem[]
  examinationOnlineExams ExaminationOnlineExam[]
  examinationResults ExaminationResult[]
  reportCards ReportCard[]
  lmsCourses LmsCourse[]
  lmsMaterials LmsMaterial[]
  lmsVideos LmsVideo[]
  lmsQuizzes LmsQuiz[]
  lmsProgressRecords LmsProgress[]
  financeInvoices FinanceInvoice[]
  financePayments FinancePayment[]
  financeScholarships FinanceScholarship[]
  financeDiscounts FinanceDiscount[]
  financeReports FinanceReport[]
  generalLedgerEntries GeneralLedgerEntry[]
  chartOfAccounts ChartOfAccount[]
  budgetRecords BudgetRecord[]
  expenseRecords ExpenseRecord[]
  financialStatements FinancialStatement[]
  userTwoFactorSettings UserTwoFactorSetting[]
  securitySecrets SecuritySecret[]
  apiSecurityRules ApiSecurityRule[]
  securityBackupPolicies SecurityBackupPolicy[]
  performanceChecks PerformanceCheck[]
  accessibilityAudits AccessibilityAudit[]
  seoChecks SeoCheck[]
  errorMonitoringEvents ErrorMonitoringEvent[]
  deploymentChecks DeploymentCheck[]
  loadTestResults LoadTestResult[]
  regressionChecks RegressionCheck[]
  hrEmployees HrEmployee[]
  hrLeaves HrLeave[]
  hrPayrolls HrPayroll[]
  hrSalarySlips HrSalarySlip[]
  libraryIssues LibraryIssue[]
  libraryReturns LibraryReturn[]
  libraryFines LibraryFine[]
  communicationSms CommunicationSms[]
  communicationEmails CommunicationEmail[]
  communicationPushNotifications CommunicationPushNotification[]
  communicationMessages CommunicationMessage[]
  communicationAnnouncements CommunicationAnnouncement[]
  studentAnalyticsReports StudentAnalyticsReport[]
  teacherAnalyticsReports TeacherAnalyticsReport[]
  attendanceAnalyticsReports AttendanceAnalyticsReport[]
  financialAnalyticsReports FinancialAnalyticsReport[]
  analyticsDashboards AnalyticsDashboard[]
  studentDocuments DocumentStudent[]
  teacherDocuments DocumentTeacher[]
  documentContracts DocumentContract[]
  documentArchives DocumentArchive[]
  certificateRecords CertificateRecord[]
  transcriptRecords TranscriptRecord[]
  certificateVerifications CertificateVerification[]
  meetingSchedules MeetingSchedule[]
  meetingMinutes MeetingMinute[]
  meetingRecords MeetingRecord[]
  websitePages WebsitePage[]
  blogPosts BlogPost[]
  newsItems NewsItem[]
  websiteAnnouncements WebsiteAnnouncement[]
  admissionPages CmsAdmissionPage[]
  mobileDevices MobileDevice[]
  mobileSyncLogs MobileSyncLog[]
  campuses Campus[]

  @@index([status])
  @@index([deletedAt])
}

model Campus {
  id        String   @id @default(cuid())
  schoolId  String
  name      String
  code      String
  status    String   @default("ACTIVE")
  address   String?
  phone     String?
  email     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  school    School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@unique([schoolId, code])
  @@index([schoolId, status])
  @@index([status])
}

model Role {
  id          String             @id @default(cuid())
  code        RoleCode           @unique
  name        String
  description String
  memberships SchoolMembership[]
}

model SchoolMembership {
  id        String           @id @default(cuid())
  userId    String
  schoolId  String?
  roleId    String
  status    MembershipStatus @default(ACTIVE)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  school    School?          @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  role      Role             @relation(fields: [roleId], references: [id])

  @@unique([userId, schoolId, roleId])
  @@index([schoolId])
  @@index([userId])
  @@index([roleId])
}

model Session {
  id           String        @id @default(cuid())
  userId       String
  membershipId String?
  refreshHash  String
  status       SessionStatus @default(ACTIVE)
  expiresAt    DateTime
  createdAt    DateTime      @default(now())
  revokedAt    DateTime?
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([membershipId])
}

model AuditLog {
  id         String      @id @default(cuid())
  userId     String?
  schoolId   String?
  action     AuditAction
  resource   String
  resourceId String?
  metadata   Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime    @default(now())
  user       User?       @relation(fields: [userId], references: [id])
  school     School?     @relation(fields: [schoolId], references: [id])

  @@index([schoolId, createdAt])
  @@index([userId, createdAt])
  @@index([action])
}

model SubscriptionPlan {
  id            String         @id @default(cuid())
  name          String         @unique
  description   String?
  monthlyAmount Int
  annualAmount  Int
  currency      String         @default("USD")
  isActive      Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  subscriptions Subscription[]
}

model Subscription {
  id                 String             @id @default(cuid())
  schoolId           String
  planId             String
  status             SubscriptionStatus @default(TRIAL)
  billingCycle       String             @default("MONTHLY")
  currentPeriodStart DateTime
  currentPeriodEnd   DateTime
  amount             Int
  currency           String             @default("USD")
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  school             School             @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  plan               SubscriptionPlan   @relation(fields: [planId], references: [id])

  @@index([schoolId])
  @@index([planId])
  @@index([status])
  @@index([currentPeriodStart])
}

model SystemSetting {
  id          String   @id @default(cuid())
  key         String   @unique
  value       Json
  description String?
  isSecret    Boolean  @default(false)
  updatedById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model BackupJob {
  id          String       @id @default(cuid())
  status      BackupStatus @default(COMPLETED)
  filePath    String
  fileSize    Int
  checksum    String
  createdById String?
  restoredAt  DateTime?
  metadata    Json?
  createdAt   DateTime     @default(now())

  @@index([status])
  @@index([createdAt])
}

model UserTwoFactorSetting {
  id              String   @id @default(cuid())
  userId          String
  schoolId        String?
  secretEncrypted String
  algorithm       String   @default("TOTP_SHA1")
  enabled         Boolean  @default(false)
  verifiedAt      DateTime?
  recoveryCodes   Json?
  status          String   @default("PENDING")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  school          School?  @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@unique([userId, schoolId])
  @@index([schoolId, status])
  @@index([userId, enabled])
}

model SecuritySecret {
  id             String   @id @default(cuid())
  schoolId       String?
  key            String
  encryptedValue String
  iv             String
  authTag        String
  algorithm      String   @default("AES-256-GCM")
  status         String   @default("ACTIVE")
  rotatedAt      DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  school         School?  @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@unique([schoolId, key])
  @@index([schoolId, status])
  @@index([key])
}

model ApiSecurityRule {
  id          String   @id @default(cuid())
  schoolId    String?
  name        String
  ruleType    String
  pattern     String
  action      String
  severity    String   @default("MEDIUM")
  status      String   @default("ACTIVE")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  school      School?  @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@unique([schoolId, name])
  @@index([schoolId, status])
  @@index([ruleType])
  @@index([severity])
}

model SecurityBackupPolicy {
  id                String   @id @default(cuid())
  schoolId          String?
  name              String
  frequency         String
  retentionDays     Int      @default(30)
  storageTarget     String
  encryptionEnabled Boolean  @default(true)
  lastBackupAt      DateTime?
  status            String   @default("ACTIVE")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  school            School?  @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@unique([schoolId, name])
  @@index([schoolId, status])
  @@index([frequency])
}

model PerformanceCheck {
  id          String   @id @default(cuid())
  schoolId    String?
  area        String
  metric      String
  value       Int
  unit        String
  threshold   Int
  status      String   @default("PASS")
  checkedAt   DateTime @default(now())
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  school      School?  @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([schoolId, status])
  @@index([area])
  @@index([checkedAt])
}

model AccessibilityAudit {
  id          String   @id @default(cuid())
  schoolId    String?
  page        String
  rule        String
  impact      String
  status      String   @default("PASS")
  checkedAt   DateTime @default(now())
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  school      School?  @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([schoolId, status])
  @@index([page])
  @@index([impact])
}

model SeoCheck {
  id          String   @id @default(cuid())
  schoolId    String?
  page        String
  title       String
  description String
  canonical   String?
  status      String   @default("PASS")
  checkedAt   DateTime @default(now())
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  school      School?  @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([schoolId, status])
  @@index([page])
}

model ErrorMonitoringEvent {
  id          String   @id @default(cuid())
  schoolId    String?
  source      String
  severity    String   @default("ERROR")
  message     String
  stack       String?
  status      String   @default("OPEN")
  occurredAt  DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  school      School?  @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([schoolId, status])
  @@index([severity])
  @@index([occurredAt])
}

model DeploymentCheck {
  id          String   @id @default(cuid())
  schoolId    String?
  environment String
  checkName   String
  status      String   @default("PASS")
  checkedAt   DateTime @default(now())
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  school      School?  @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([schoolId, status])
  @@index([environment])
  @@index([checkedAt])
}

model LoadTestResult {
  id                String   @id @default(cuid())
  schoolId          String?
  scenario          String
  virtualUsers      Int
  durationSeconds   Int
  requestsPerSecond Int
  p95Ms             Int
  errorRate         Int
  status            String   @default("PASS")
  testedAt          DateTime @default(now())
  notes             String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  school            School?  @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([schoolId, status])
  @@index([scenario])
  @@index([testedAt])
}

model RegressionCheck {
  id        String   @id @default(cuid())
  schoolId  String?
  suite     String
  checkName String
  status    String   @default("PASS")
  checkedAt DateTime @default(now())
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  school    School?  @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([schoolId, status])
  @@index([suite])
  @@index([checkedAt])
}

model AcademicYear {
  id        String   @id @default(cuid())
  schoolId  String
  name      String
  startsOn  DateTime
  endsOn    DateTime
  status    String   @default("ACTIVE")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  school    School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@unique([schoolId, name])
  @@index([schoolId, status])
}

model ClassLevel {
  id        String   @id @default(cuid())
  schoolId  String
  name      String
  code      String
  status    String   @default("ACTIVE")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  school    School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  sections  Section[]

  @@unique([schoolId, code])
  @@index([schoolId, status])
}

model Section {
  id        String     @id @default(cuid())
  schoolId  String
  classId   String
  name      String
  capacity  Int        @default(40)
  status    String     @default("ACTIVE")
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  school    School     @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  class     ClassLevel @relation(fields: [classId], references: [id], onDelete: Cascade)

  @@unique([schoolId, classId, name])
  @@index([schoolId, status])
}

model Subject {
  id        String   @id @default(cuid())
  schoolId  String
  name      String
  code      String
  type      String   @default("CORE")
  status    String   @default("ACTIVE")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  school    School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@unique([schoolId, code])
  @@index([schoolId, status])
}

model TeacherProfile {
  id             String   @id @default(cuid())
  schoolId       String
  employeeNumber String
  name           String
  email          String
  phone          String?
  specialization String?
  status         String   @default("ACTIVE")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  school         School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@unique([schoolId, employeeNumber])
  @@unique([schoolId, email])
  @@index([schoolId, status])
}

model StudentProfile {
  id              String   @id @default(cuid())
  schoolId        String
  admissionNumber String
  name            String
  guardianName    String
  guardianPhone   String
  className       String
  status          String   @default("ACTIVE")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  school          School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  leaveRequests   LeaveRequest[]

  @@unique([schoolId, admissionNumber])
  @@index([schoolId, status])
}

model LeaveRequest {
  id              String             @id @default(cuid())
  schoolId        String
  studentId       String
  requestedById   String
  type            LeaveRequestType
  status          LeaveRequestStatus @default(SUBMITTED)
  startDate       DateTime
  endDate         DateTime
  startTime       String?
  endTime         String?
  reason          String
  parentNote      String?
  reviewerId      String?
  reviewerComment String?
  reviewedAt      DateTime?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  school          School             @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  student         StudentProfile     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  requestedBy     User               @relation("LeaveRequestRequestedBy", fields: [requestedById], references: [id], onDelete: Cascade)
  reviewer        User?              @relation("LeaveRequestReviewedBy", fields: [reviewerId], references: [id], onDelete: SetNull)
  timeline        LeaveRequestTimeline[]

  @@index([schoolId, status])
  @@index([schoolId, studentId])
  @@index([schoolId, requestedById])
  @@index([schoolId, startDate])
}

model LeaveRequestTimeline {
  id             String       @id @default(cuid())
  leaveRequestId String
  actorId        String?
  action         String
  note           String?
  createdAt      DateTime     @default(now())
  leaveRequest   LeaveRequest @relation(fields: [leaveRequestId], references: [id], onDelete: Cascade)
  actor          User?        @relation("LeaveRequestTimelineActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([leaveRequestId, createdAt])
  @@index([actorId])
}
model FeeRecord {
  id        String   @id @default(cuid())
  schoolId  String
  title     String
  amount    Int
  dueDate   DateTime
  status    String   @default("PENDING")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  school    School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([schoolId, status])
}

model ExamRecord {
  id        String   @id @default(cuid())
  schoolId  String
  name      String
  subject   String
  examDate  DateTime
  status    String   @default("SCHEDULED")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  school    School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([schoolId, status])
}

model AttendanceRecord {
  id        String   @id @default(cuid())
  schoolId  String
  personName String
  personType String
  attendanceDate DateTime
  status    String   @default("PRESENT")
  remarks   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  school    School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([schoolId, status])
  @@index([schoolId, attendanceDate])
}

model AttendanceNotification {
  id            String   @id @default(cuid())
  schoolId      String
  recipientName String
  recipientType String
  channel       String   @default("PORTAL")
  message       String
  status        String   @default("QUEUED")
  sentAt        DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  school        School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([schoolId, status])
  @@index([schoolId, recipientType])
  @@index([schoolId, createdAt])
}

model LibraryBook {
  id        String   @id @default(cuid())
  schoolId  String
  title     String
  author    String
  isbn      String
  copies    Int      @default(1)
  status    String   @default("AVAILABLE")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  school    School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@unique([schoolId, isbn])
  @@index([schoolId, status])
}

model LibraryIssue {
  id         String   @id @default(cuid())
  schoolId   String
  bookTitle  String
  isbn       String
  borrowerName String
  borrowerType String
  issuedOn   DateTime @default(now())
  dueOn      DateTime
  status     String   @default("ISSUED")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  school     School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([schoolId, status])
  @@index([schoolId, borrowerName])
  @@index([schoolId, dueOn])
}

model LibraryReturn {
  id          String   @id @default(cuid())
  schoolId    String
  bookTitle   String
  isbn        String
  borrowerName String
  returnedOn  DateTime @default(now())
  condition   String   @default("GOOD")
  status      String   @default("RETURNED")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  school      School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([schoolId, status])
  @@index([schoolId, borrowerName])
  @@index([schoolId, returnedOn])
}

model LibraryFine {
  id           String   @id @default(cuid())
  schoolId     String
  borrowerName String
  bookTitle    String
  amount       Int
  reason       String
  issuedOn     DateTime @default(now())
  status       String   @default("PENDING")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  school       School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([schoolId, status])
  @@index([schoolId, borrowerName])
  @@index([schoolId, issuedOn])
}

model CommunicationSms {
  id            String   @id @default(cuid())
  schoolId      String
  recipientName String
  phone         String
  message       String
  sentAt        DateTime?
  status        String   @default("QUEUED")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  school        School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([schoolId, status])
  @@index([schoolId, recipientName])
  @@index([schoolId, createdAt])
}

model CommunicationEmail {
  id            String   @id @default(cuid())
  schoolId      String
  recipientName String
  email         String
  subject       String
  body          String
  sentAt        DateTime?
  status        String   @default("QUEUED")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  school        School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([schoolId, status])
  @@index([schoolId, recipientName])
  @@index([schoolId, createdAt])
}

model CommunicationPushNotification {
