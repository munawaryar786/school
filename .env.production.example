# ==========================================
# PRODUCTION ENVIRONMENT VARIABLES
# ==========================================
# Copy this to Vercel Environment Variables
# DO NOT commit this file to Git
# DO NOT put real values in this file
# ==========================================

# ==========================================
# DATABASE - REQUIRED
# ==========================================
# For Neon PostgreSQL (Recommended - Free, SSL included):
# 1. Go to https://neon.tech
# 2. Create project
# 3. Copy connection string from dashboard
# 4. Format: postgresql://user:password@host:port/database?sslmode=require
# 5. Note: ?sslmode=require is REQUIRED for Neon
DATABASE_URL="postgresql://neondb_owner:password@ep-xxxxx.region.neon.tech:5432/neondb?sslmode=require"

# For AWS RDS (if using RDS instead):
# DATABASE_URL="postgresql://postgres:password@endpoint:5432/school_db?schema=public"

# For Railway:
# DATABASE_URL="postgresql://user:password@db.railway.app:5432/school_db"

# For Supabase:
# DATABASE_URL="postgresql://user:password@db.supabase.co:5432/postgres"

# ==========================================
# AUTHENTICATION - REQUIRED
# ==========================================
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_ACCESS_SECRET="your-random-32-char-hex-string-here-minimum-32-characters"
JWT_REFRESH_SECRET="your-another-32-char-hex-string-here-minimum-32-characters"
ACCESS_TOKEN_EXPIRES_IN="15m"
REFRESH_TOKEN_EXPIRES_IN="7d"

# ==========================================
# APPLICATION - REQUIRED
# ==========================================
NODE_ENV="production"
API_PORT="4000"
LOG_LEVEL="info"

# ==========================================
# CORS CONFIGURATION - REQUIRED
# ==========================================
# Set to your production domain
WEB_ORIGIN="https://yourdomain.com"
NEXT_PUBLIC_API_URL="https://api.yourdomain.com"

# ==========================================
# EMAIL SERVICE - RECOMMENDED
# ==========================================
# SendGrid
EMAIL_PROVIDER="sendgrid"
SENDGRID_API_KEY="SG.your_sendgrid_api_key_here"

# OR use SMTP
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"

# ==========================================
# FILE STORAGE - RECOMMENDED
# ==========================================
# AWS S3
S3_BUCKET="school-erp-files"
S3_REGION="us-east-1"
S3_ACCESS_KEY="AKIAIOSFODNN7EXAMPLE"
S3_SECRET_KEY="wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY"

# ==========================================
# PAYMENT PROCESSING - OPTIONAL
# ==========================================
# Stripe
STRIPE_SECRET_KEY="sk_live_your_stripe_secret_key"
STRIPE_PUBLISHABLE_KEY="pk_live_your_stripe_public_key"

# ==========================================
# ERROR MONITORING - RECOMMENDED
# ==========================================
SENTRY_DSN="https://your_key@sentry.io/your_project_id"

# ==========================================
# SMS SERVICE - OPTIONAL
# ==========================================
# Twilio
SMS_PROVIDER="twilio"
TWILIO_ACCOUNT_SID="ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
TWILIO_AUTH_TOKEN="your_twilio_auth_token"
TWILIO_PHONE_NUMBER="+1234567890"

# ==========================================
# ADDITIONAL SERVICES - OPTIONAL
# ==========================================
# Redis for caching/sessions
REDIS_URL="redis://user:password@redis.host:6379"

# Google Analytics
NEXT_PUBLIC_GA_ID="G-XXXXXXXXXX"

# ==========================================
# SETUP INSTRUCTIONS
# ==========================================
# 1. Create production database (Railway/AWS RDS/Supabase)
# 2. Generate strong JWT secrets: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# 3. Setup email service (SendGrid recommended)
# 4. Setup S3 bucket for file storage
# 5. Add all these to Vercel Project Settings → Environment Variables
# 6. Set them for Production environment
# 7. Redeploy the project
# 8. Test all endpoints after deployment
